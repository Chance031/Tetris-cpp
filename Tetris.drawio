          <mxGeometry height="40" width="400" x="80" y="40" as="geometry" />
        </mxCell>
        <mxCell id="EURBDBcKlBXKIeO3a-4L-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeWidth=2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;단일 유효성 검사 원칙 — 이 함수가 호출되는 모든 상황&lt;/b&gt;&lt;hr/&gt;① 좌/우 이동 후 검증&lt;br&gt;② 회전 후 검증 (Wall Kick 재검증 포함)&lt;br&gt;③ 자동 낙하 후 검증&lt;br&gt;④ 소프트 드롭 후 검증&lt;br&gt;⑤ 하드 드롭 최종 낙하 위치 계산&lt;br&gt;⑥ SpawnNextPiece() — 스폰 가능 여부 (= 게임오버 판정)" vertex="1">
          <mxGeometry height="160" width="290" x="520" y="40" as="geometry" />
        </mxCell>
        <mxCell id="EURBDBcKlBXKIeO3a-4L-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeWidth=2;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;[확정] cy &lt; 0 스폰 정책&lt;/b&gt;&lt;hr/&gt;cy &lt; 0 인 셀은 CanPlace()에서 &lt;b&gt;허용 (통과)&lt;/b&gt;&lt;br&gt;보드 배열 접근(board[cy][cx])은 &lt;b&gt;cy ≥ 0 일 때만&lt;/b&gt;&lt;br&gt;→ if (cy &gt;= 0 &amp;&amp; board[cy][cx] != 0) 형태로 guard&lt;br&gt;cy &lt; 0이면 범위·겹침 검사 모두 스킵" vertex="1">
          <mxGeometry height="110" width="290" x="520" y="210" as="geometry" />
        </mxCell>
        <mxCell id="EURBDBcKlBXKIeO3a-4L-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeWidth=2;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=8;" value="&lt;b&gt;GetBlockLocations() 반환 구조 [확정]&lt;/b&gt;&lt;hr/&gt;반환 타입: std::array&lt;Point, 4&gt;&lt;br&gt;블록 기준위치(x,y) + int[4][4] 회전 데이터 → 4개 절대좌표&lt;br&gt;예) {cx, cy} = {piece.x + offset.x, piece.y + offset.y}" vertex="1">
