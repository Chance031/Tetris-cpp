{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Build Tetris (Debug x64)",
      "runtimeExecutable": "msbuild",
      "runtimeArgs": ["Tetris/Tetris.slnx", "/p:Configuration=Debug", "/p:Platform=x64", "/m"],
      "port": null
    },
    {
      "name": "Build Tetris (Release x64)",
      "runtimeExecutable": "msbuild",
      "runtimeArgs": ["Tetris/Tetris.slnx", "/p:Configuration=Release", "/p:Platform=x64", "/m"],
      "port": null
    },
    {
      "name": "Update Gantt Chart (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["scripts/update_gantt.py"],
      "port": null
    }
  ]
}
